# =============================================================================
# Secure DMS — Environment Configuration
# Copy this file to .env and adjust values for your deployment.
# =============================================================================

## --- General ---
DOMAIN=localhost
EMAIL=                    # Let's Encrypt email (leave empty for localhost)
JWT_SECRET=changeme-use-a-real-256bit-secret-in-production-please

## --- PostgreSQL ---
POSTGRES_DB=secure_dms
POSTGRES_USER=dms_user
POSTGRES_PASSWORD=dms_secret

## --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET=secure-dms

## --- Backend ---
SPRING_PROFILES_ACTIVE=s3
